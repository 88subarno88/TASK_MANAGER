# MongoDB Connection String
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/taskmanager

# JWT Secret (min 32 chars, random string)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long

# AES Encryption Key (exactly 32 chars for AES-256)
ENCRYPTION_KEY=your_32_char_encryption_key_here!

# Encryption IV Salt (16 chars)
ENCRYPTION_IV_SALT=your_16_char_salt!

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cookie Settings
NODE_ENV=development
